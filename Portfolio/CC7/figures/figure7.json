{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Change in Economic Complexity Index from 1993 to 2022",
    "subtitle": [
      "Ranking of countries, 2022",
      "Source: The Harvard Atlas of Economic Complexity",
      ""
    ],
    "fontSize": 16,
    "subtitleFontSize": 12,
    "subtitleFontWeight": "lighter",
    "anchor": "middle"
  },
  "description": "2022 World Bank data, GDP per capita in current international $ and converted to purchasing power parity. Grey countries have missing data.",
  "data": { 
    "url": "https://raw.githubusercontent.com/IgnacioOrueta/ignacioorueta.github.io/refs/heads/main/Portfolio/CC7/map_data2022.csv"
  },
  "width": 600,
  "height": 330,
  
  "transform": [
    {
      "lookup": "ISO3",
      "from": {
        "key": "properties.ISO3",
        "fields": ["type", "geometry", "properties"],
        "data": {
          "url": "https://raw.githubusercontent.com/EconomicsObservatory/courses/main/datasets/advanced/map_world.geojson",
          "format": {"property": "features"}
        }
      }
    },
    {
      "calculate": "datum.hs_eci_rank + (datum.hs_eci_rank == 1 ? 'st' : datum.hs_eci_rank == 2 ? 'nd' : datum.hs_eci_rank == 3 ? 'rd' : 'th')",
      "as": "rank_with_suffix"
    }
  ],
  "projection": {
    "type": "naturalEarth1",
    "scale": 125,
    "translate": [285, 180]
  },
  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 0.3
  },
  "encoding": {
    "color": {
      "condition": {
        "value": "lightgrey",
        "test": "!datum['hs_eci_rank']"
      },
      "field": "hs_eci_rank",
      "type": "quantitative",
      "legend": {
        "title": "Ranking",
        "format": "d",
        "direction": "vertical"
      },
      "scale": {
        "type": "linear",
        "domain": [10, 120],
        "nice": true,
        "scheme": "viridis",
        "reverse": true
      } 
    },
    "tooltip": [
      {"field": "country", "title": "Country"},
      {"field": "rank_with_suffix", "title": "Ranking"}
    ]
  }
}